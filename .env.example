# Copia in .env e compila i valori
# Chiave Django: in produzione usa solo DJANGO_SECRET_KEY (stringa lunga e casuale).
DJANGO_SECRET_KEY=genera-una-key-lunga-e-random-qui
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development
DB_NAME=axdoc
DB_USER=axdoc
DB_PASSWORD=axdoc_password
DB_HOST=db
DB_PORT=3306
MYSQL_DATABASE=axdoc
MYSQL_USER=axdoc
MYSQL_PASSWORD=axdoc_password
MYSQL_ROOT_PASSWORD=root_password
REDIS_URL=redis://redis:6379/0
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
# JWT: access default 30 min; refresh default 8 h (FASE 28)
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_HOURS=8
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@axdoc.local
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
VITE_API_URL=http://localhost:8000
